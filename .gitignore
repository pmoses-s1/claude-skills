# Secrets — never commit
**/config.json
# Don't commit a real credentials.json. Anywhere. The example file
# (credentials.example.json) is safe to track.
**/credentials.json
*.env
.env.*
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
